# ============================================================
# GeoPunch 考勤系统 - 环境变量配置示例
# Copy to .env and fill in actual values
# ============================================================

# ====================
# 应用配置
# ====================
NODE_ENV=development
PORT=3000
TZ=Asia/Shanghai

# ====================
# 数据库配置 (MySQL)
# ====================
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=geopunch
DATABASE_USER=geopunch
DATABASE_PASSWORD=geopunch123
DATABASE_URL=mysql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# ====================
# Redis 配置
# ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ====================
# JWT 配置
# ====================
JWT_SECRET=change-this-to-a-secure-secret-in-production
JWT_REFRESH_SECRET=change-this-to-a-secure-refresh-secret-in-production
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ====================
# MinIO 对象存储配置
# ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=geopunch-photos
MINIO_USE_SSL=false

# ====================
# 微信小程序配置
# ====================
WECHAT_APPID=your-wechat-appid
WECHAT_SECRET=your-wechat-secret

# ====================
# 地图API配置 (高德/腾讯)
# ====================
AMAP_KEY=your-amap-key
AMAP_SECURITY_KEY=your-amap-security-key
TENCENT_MAP_KEY=your-tencent-map-key

# ====================
# 业务配置
# ====================
ATTENDANCE_WORK_START=09:00
ATTENDANCE_WORK_END=18:00
ATTENDANCE_LATE_THRESHOLD_MINUTES=30
ATTENDANCE_EARLY_LEAVE_THRESHOLD_MINUTES=30
ATTENDANCE_GPS_RADIUS_DEFAULT=200
MAKEUP_WINDOW_DAYS=3
MAX_MAKEUP_PER_MONTH=3
LATE_GRACE_MINUTES=3

# ====================
# 日志配置
# ====================
LOG_LEVEL=info
LOG_FORMAT=json

# ====================
# 飞书/钉钉配置 (可选)
# ====================
FEISHU_WEBHOOK_URL=
DINGTALK_WEBHOOK_URL=

# ====================
# Sentry 配置 (可选)
# ====================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
