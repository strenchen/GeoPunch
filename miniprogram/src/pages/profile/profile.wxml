<view class="container">
  <!-- 登录表单 -->
  <view class="login-wrapper" wx:if="{{!isLoggedIn}}">
    <!-- 顶部品牌区域 -->
    <view class="brand-section">
      <view class="logo-wrap">
        <text class="logo-text">GP</text>
      </view>
      <text class="brand-name">GeoPunch</text>
      <text class="brand-slogan">智慧考勤 · 让工作更高效</text>
    </view>

    <!-- 登录卡片 -->
    <view class="login-card">
      <text class="card-title">员工登录</text>

      <!-- 工号输入 -->
      <view class="input-group">
        <view class="input-prefix">
          <text class="input-icon-text">👤</text>
        </view>
        <input
          class="login-input"
          placeholder="请输入工号"
          placeholder-class="placeholder"
          bindinput="onEmployeeNumberInput"
          value="{{employeeNumber}}"
        />
      </view>

      <!-- 密码输入 -->
      <view class="input-group">
        <view class="input-prefix">
          <text class="input-icon-text">🔒</text>
        </view>
        <input
          class="login-input"
          password
          placeholder="请输入密码"
          placeholder-class="placeholder"
          bindinput="onPasswordInput"
          value="{{password}}"
        />
      </view>

      <!-- 登录按钮 -->
      <button class="login-btn" bindtap="doLogin">
        <text class="login-btn-text">登 录</text>
      </button>
    </view>

    <!-- 底部版权 -->
    <text class="copyright">© 2026 GeoPunch 考勤系统</text>
  </view>

  <!-- 用户信息 -->
  <view class="profile-wrapper" wx:else>
    <!-- 用户信息卡片 -->
    <view class="profile-card">
      <view class="user-header">
        <view class="avatar-wrap">
          <view class="avatar-placeholder">
            <text class="avatar-text">{{userInfo.name ? userInfo.name[0] : '👤'}}</text>
          </view>
          <view class="avatar-badge" wx:if="{{isAdmin}}">管理</view>
        </view>
        <view class="user-info">
          <text class="username">{{userInfo.name}}</text>
          <text class="employee-no">工号 {{userInfo.employeeNumber}}</text>
          <view class="dept-tag">
            <text class="dept-text">{{userInfo.department}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 考勤概览 -->
    <view class="stats-card">
      <text class="stats-title">考勤概览</text>
      <view class="stats-grid">
        <view class="stats-item">
          <view class="stats-ring ring-blue">
            <text class="stats-value">{{stats.attendanceRate || 0}}%</text>
          </view>
          <text class="stats-label">出勤率</text>
        </view>
        <view class="stats-item">
          <view class="stats-ring ring-red">
            <text class="stats-value">{{stats.lateDays || 0}}</text>
          </view>
          <text class="stats-label">迟到次数</text>
        </view>
        <view class="stats-item">
          <view class="stats-ring ring-orange">
            <text class="stats-value">{{stats.earlyLeaveDays || 0}}</text>
          </view>
          <text class="stats-label">早退次数</text>
        </view>
        <view class="stats-item">
          <view class="stats-ring ring-green">
            <text class="stats-value">{{stats.makeupDays || 0}}</text>
          </view>
          <text class="stats-label">补卡申请</text>
        </view>
      </view>
    </view>

    <!-- 菜单列表 -->
    <view class="menu-card">
      <view class="menu-item" bindtap="goToLeave">
        <view class="menu-icon-wrap bg-green">
          <text class="menu-icon-text">📝</text>
        </view>
        <text class="menu-text">请假申请</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToMakeup">
        <view class="menu-icon-wrap bg-blue">
          <text class="menu-icon-text">⏰</text>
        </view>
        <text class="menu-text">补卡申请</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goToRecords">
        <view class="menu-icon-wrap bg-purple">
          <text class="menu-icon-text">📋</text>
        </view>
        <text class="menu-text">打卡记录</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" wx:if="{{isAdmin}}" bindtap="goToApproval">
        <view class="menu-icon-wrap bg-orange">
          <text class="menu-icon-text">✅</text>
        </view>
        <text class="menu-text">审批管理</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- 设置菜单 -->
    <view class="menu-card">
      <view class="menu-item">
        <view class="menu-icon-wrap bg-gray">
          <text class="menu-icon-text">⚙️</text>
        </view>
        <text class="menu-text">设置</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item">
        <view class="menu-icon-wrap bg-gray">
          <text class="menu-icon-text">❓</text>
        </view>
        <text class="menu-text">帮助与反馈</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item">
        <view class="menu-icon-wrap bg-gray">
          <text class="menu-icon-text">ℹ️</text>
        </view>
        <text class="menu-text">关于</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <!-- 退出登录 -->
    <button class="logout-btn" bindtap="doLogout">退出登录</button>
  </view>
</view>
