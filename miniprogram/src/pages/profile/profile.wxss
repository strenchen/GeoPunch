/* pages/profile/profile.wxss */

/* ========== 全局容器 ========== */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f5ff 0%, #f5f5f5 100%);
}

/* ========== 登录页面 ========== */
.login-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
}

/* 品牌区域 */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
}

.logo-wrap {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #1890ff 0%, #52c4ff 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(24, 144, 255, 0.3);
  margin-bottom: 24rpx;
}

.logo-text {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.brand-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #1890ff;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.brand-slogan {
  font-size: 26rpx;
  color: #8c8c8c;
  letter-spacing: 2rpx;
}

/* 登录卡片 */
.login-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 40rpx;
  text-align: center;
}

/* 输入框组 */
.input-group {
  display: flex;
  align-items: center;
  background: #f7f8fa;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.input-group:focus-within {
  border-color: #1890ff;
  background: #fff;
}

.input-prefix {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.input-icon-text {
  font-size: 36rpx;
}

.login-input {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: #262626;
  background: transparent;
}

.placeholder {
  color: #bfbfbf;
  font-size: 28rpx;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #1890ff 0%, #52c4ff 100%);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.35);
  margin-top: 16rpx;
  border: none;
}

.login-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.login-btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 8rpx;
}

/* 版权 */
.copyright {
  font-size: 22rpx;
  color: #bfbfbf;
  margin-top: 60rpx;
  margin-bottom: 40rpx;
}

/* ========== 个人信息页面 ========== */
.profile-wrapper {
  padding: 24rpx;
}

/* 用户信息卡片 */
.profile-card {
  background: linear-gradient(135deg, #1890ff 0%, #52c4ff 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(24, 144, 255, 0.25);
}

.user-header {
  display: flex;
  align-items: center;
}

.avatar-wrap {
  position: relative;
  margin-right: 28rpx;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
}

.avatar-text {
  font-size: 52rpx;
  color: #fff;
  font-weight: 600;
}

.avatar-badge {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.username {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
}

.employee-no {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 12rpx;
}

.dept-tag {
  display: inline-flex;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 8rpx;
  padding: 4rpx 16rpx;
  align-self: flex-start;
}

.dept-text {
  font-size: 24rpx;
  color: #fff;
}

/* 考勤概览 */
.stats-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.stats-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 28rpx;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
}

.stats-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-ring {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.stats-ring.ring-blue {
  background: linear-gradient(135deg, #e6f7ff 0%, #bae7ff 100%);
}

.stats-ring.ring-red {
  background: linear-gradient(135deg, #fff1f0 0%, #ffccc7 100%);
}

.stats-ring.ring-orange {
  background: linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%);
}

.stats-ring.ring-green {
  background: linear-gradient(135deg, #f6ffed 0%, #d9f7be 100%);
}

.stats-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #1890ff;
}

.stats-ring.ring-red .stats-value {
  color: #ff4d4f;
}

.stats-ring.ring-orange .stats-value {
  color: #fa8c16;
}

.stats-ring.ring-green .stats-value {
  color: #52c41a;
}

.stats-label {
  font-size: 22rpx;
  color: #8c8c8c;
}

/* 菜单卡片 */
.menu-card {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon-wrap.bg-green {
  background: linear-gradient(135deg, #f6ffed 0%, #d9f7be 100%);
}

.menu-icon-wrap.bg-blue {
  background: linear-gradient(135deg, #e6f7ff 0%, #bae7ff 100%);
}

.menu-icon-wrap.bg-purple {
  background: linear-gradient(135deg, #f9f0ff 0%, #e9d5ff 100%);
}

.menu-icon-wrap.bg-orange {
  background: linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%);
}

.menu-icon-wrap.bg-gray {
  background: linear-gradient(135deg, #f7f8fa 0%, #e8e8e8 100%);
}

.menu-icon-text {
  font-size: 32rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #262626;
}

.menu-arrow {
  font-size: 36rpx;
  color: #bfbfbf;
}

/* 退出按钮 */
.logout-btn {
  width: 100%;
  height: 96rpx;
  background: #fff;
  color: #ff4d4f;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  margin-top: 8rpx;
  margin-bottom: 40rpx;
  border: 2rpx solid #ff4d4f;
}

.logout-btn:active {
  background: #fff1f0;
}
