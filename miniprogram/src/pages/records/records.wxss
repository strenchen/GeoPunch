/* pages/records/records.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.month-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.month-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #1890ff;
}

.month-display {
  flex: 1;
  text-align: center;
}

.month-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.records-list {
  display: flex;
  flex-direction: column;
}

.record-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.record-date {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.date-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.weekday-text {
  font-size: 26rpx;
  color: #999;
}

.record-detail {
  display: flex;
  flex-direction: column;
}

.record-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-label {
  width: 80rpx;
  font-size: 28rpx;
  color: #666;
}

.record-time {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.record-time.late {
  color: #ff4d4f;
}

.record-time.early {
  color: #faad14;
}

.record-time.absent {
  color: #999;
}

.status-tag {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-left: 16rpx;
}

.status-tag.normal {
  background: #f6ffed;
  color: #52c41a;
}

.status-tag.late {
  background: #fff1f0;
  color: #ff4d4f;
}

.status-tag.early {
  background: #fffbe6;
  color: #faad14;
}

.status-tag.absent {
  background: #f5f5f5;
  color: #999;
}

.record-location {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.location-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 8rpx;
}

.location-text {
  font-size: 24rpx;
  color: #999;
}

.apply-makeup {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: center;
  color: #1890ff;
  font-size: 28rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}

.loading-state {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}
