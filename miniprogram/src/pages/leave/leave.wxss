/* pages/leave/leave.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.balance-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.balance-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.balance-items {
  display: flex;
  justify-content: space-around;
}

.balance-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.balance-value {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.balance-value.annual {
  color: #52c41a;
}

.balance-value.sick {
  color: #1890ff;
}

.balance-value.personal {
  color: #faad14;
}

.balance-label {
  font-size: 24rpx;
  color: #999;
}

.tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  padding: 30rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}

.tab.active {
  color: #1890ff;
  border-bottom-color: #1890ff;
}

.leave-list {
  display: flex;
  flex-direction: column;
}

.leave-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.leave-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.leave-type {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.leave-status {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.leave-status.pending {
  background: #e6f7ff;
  color: #1890ff;
}

.leave-status.approved {
  background: #f6ffed;
  color: #52c41a;
}

.leave-status.rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

.leave-date {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.leave-duration {
  color: #1890ff;
  font-weight: 500;
}

.leave-reason {
  font-size: 26rpx;
  color: #999;
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
}

.leave-footer {
  display: flex;
  justify-content: flex-end;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.cancel-btn {
  background: #fff;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  font-size: 24rpx;
}

.apply-form {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.picker-value {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  min-height: 150rpx;
  box-sizing: border-box;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #1890ff;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 20rpx;
}

.submit-btn[disabled] {
  background: #ccc;
}

.empty-state {
  text-align: center;
  padding: 100rpx;
  color: #999;
  font-size: 28rpx;
}
