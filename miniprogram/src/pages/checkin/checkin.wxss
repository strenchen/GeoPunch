/* pages/checkin/checkin.wxss */
.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 打卡类型卡片 */
.type-card {
  background: linear-gradient(135deg, #1890ff, #70b0ff);
  color: #fff;
  padding: 40rpx;
  border-radius: 12rpx;
  text-align: center;
  margin-bottom: 20rpx;
}


.type-text {
  font-size: 40rpx;
  font-weight: 700;
}


.location-card,
.status-card,
.photo-card,
.result-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.location-header {
  margin-bottom: 20rpx;
}

.location-title {
  font-size: 28rpx;
  color: #999;
}

.location-info {
  display: flex;
  align-items: flex-start;
}

.location-icon {
  width: 50rpx;
  height: 50rpx;
  margin-right: 20rpx;
}

.location-detail {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.address {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.distance {
  font-size: 26rpx;
  color: #666;
}

.map-card {
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.map {
  width: 100%;
  height: 400rpx;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.status-row:last-child {
  border-bottom: none;
}

.status-label {
  font-size: 28rpx;
  color: #666;
}

.status-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.status-value.success {
  color: #52c41a;
}

.status-value.warning {
  color: #ff4d4f;
}

.photo-card {
  display: flex;
  align-items: center;
}

.photo-label {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: #333;
}

.confirm-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 20rpx;
}

.confirm-btn.active {
  background: linear-gradient(135deg, #1890ff, #70b0ff);
  color: #fff;
  box-shadow: 0 8rpx 30rpx rgba(24, 144, 255, 0.3);
}

.confirm-btn.disabled {
  background: #ccc;
  color: #fff;
}

.result-card {
  margin-top: 20rpx;
  text-align: center;
}

.result-text {
  font-size: 32rpx;
  font-weight: 600;
}

.result-text.NORMAL {
  color: #52c41a;
}

.result-text.LATE {
  color: #ff4d4f;
}

.result-text.EARLY_LEAVE {
  color: #faad14;
}
