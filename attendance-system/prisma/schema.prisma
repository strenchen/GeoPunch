// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 表0: 部门表（支持层级）
// ============================================================
model Department {
  id        Int      @id @default(autoincrement())
  name      String   @map("name")
  parentId  Int?     @map("parent_id")
  parent    Department? @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentHierarchy")
  employees Employee[]
  rules     AttendanceRule[]
  locationWhitelists LocationWhitelist[]
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("department")
}

// ============================================================
// 表0-1: 角色表（细粒度权限）
// ============================================================
model Role {
  id          Int       @id @default(autoincrement())
  name        String    @unique @map("name")
  permissions Json      @map("permissions") // 权限列表
  employees   Employee[]
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("role")
}

// ============================================================
// 枚举定义
// ============================================================
enum EmployeeType {
  LEADER     // 领导（豁免考勤）
  SALES      // 销售线
  RD_ADMIN   // 研发行政（固定时段+地点打卡）
}

enum ClockType {
  CHECK_IN   // 上班打卡
  CHECK_OUT  // 下班打卡
}

enum AttendStatus {
  NORMAL     // 正常
  LATE       // 迟到
  EARLY_LEAVE // 早退
  ABSENT     // 缺勤
  ABSENTEEISM // 旷工（恶意缺勤）
  MAKEUP     // 补卡
}

enum AbnormalType {
  GPS_OUT_OF_RANGE  // GPS不在允许范围
  SUSPICIOUS        // 可疑打卡（疑似作弊）
  REPEAT_CLOCK      // 重复打卡
}

enum AbnormalStatus {
  PENDING   // 待处理
  APPROVED  // 已处理-通过
  REJECTED  // 已处理-拒绝
}

enum LeaveType {
  ANNUAL    // 年假
  SICK      // 病假
  PERSONAL  // 事假
  MARRIAGE  // 婚假
  MATERNITY // 产假
  PATERNITY // 陪产假
  BEREAVEMENT // 丧假
  UNPAID    // 无薪假
}

enum ApproveStatus {
  PENDING   // 待审批
  APPROVED  // 已批准
  REJECTED  // 已拒绝
}

enum ConfigType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

enum RuleType {
  LEADER_EXEMPT   // 领导豁免
  SALES_CHECKIN   // 销售打卡规则
  RD_ADMIN_CHECKIN // 研发行政打卡规则
}

// ============================================================
// 表1: 员工表
// ============================================================
model Employee {
  id              Int      @id @default(autoincrement())
  employeeNumber  String   @unique @map("employee_number") // 工号
  name            String                               // 姓名
  passwordHash    String   @map("password_hash")        // 密码哈希
  phone           String?  @map("phone")               // 手机号
  departmentId    Int      @map("department_id")       // 部门ID
  department      Department @relation(fields: [departmentId], references: [id])
  position        String?                             // 岗位
  employeeType    EmployeeType @default(RD_ADMIN) @map("employee_type") // 员工类型
  roleId          Int      @map("role_id")             // 角色ID
  role            Role     @relation(fields: [roleId], references: [id])
  hireDate        DateTime  @map("hire_date")          // 入职日期
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // 关联
  attendances           Attendance[]
  leaveRequests         LeaveRequest[]
  makeupRequests        MakeupRequest[]
  approvedLeaves        LeaveRequest[]       @relation("ApproverLeave")
  approvedMakeups       MakeupRequest[]      @relation("ApproverMakeup")
  attendanceAbnormals   AttendanceAbnormal[]
  managedDepartment     LocationWhitelist[]  @relation("ManagedDepartment")
  schedules             Schedule[]
  shiftChanges          ShiftChange[]
  approvedShifts        ShiftChange[]        @relation("ApproverShift")

  @@map("employee")
}

// ============================================================
// 表2: 考勤打卡记录
// ============================================================
model Attendance {
  id         Int        @id @default(autoincrement())
  employeeId Int        @map("employee_id")
  type       ClockType  @map("type")
  checkTime  DateTime   @map("check_time")
  latitude   Float      @map("latitude")
  longitude  Float      @map("longitude")
  address    String?    @map("address")
  deviceId   String?   @map("device_id")
  photoUrl   String?   @map("photo_url")    // 拍照图片URL
  status     AttendStatus @default(NORMAL)  @map("status")
  createdAt  DateTime   @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, checkTime])
  @@index([type, checkTime])
  @@map("attendance")
}

// ============================================================
// 表3: 考勤异常记录
// ============================================================
model AttendanceAbnormal {
  id           Int            @id @default(autoincrement())
  employeeId   Int            @map("employee_id")
  type         AbnormalType   @map("type")
  latitude     Float          @map("latitude")
  longitude    Float          @map("longitude")
  address      String?        @map("address")
  deviceId     String?        @map("device_id")
  checkTime    DateTime       @map("check_time")
  status       AbnormalStatus @default(PENDING) @map("status")
  resolvedNote String?        @map("resolved_note")
  resolvedAt   DateTime?      @map("resolved_at")
  createdAt    DateTime       @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, status])
  @@index([checkTime])
  @@map("attendance_abnormal")
}

// ============================================================
// 表4: 请假申请
// ============================================================
model LeaveRequest {
  id               Int            @id @default(autoincrement())
  employeeId       Int            @map("employee_id")
  type             LeaveType      @map("type")
  startDate        DateTime       @map("start_date")
  endDate          DateTime       @map("end_date")
  reason           String         @map("reason")
  attachments      String?        @map("attachments")
  status           ApproveStatus  @default(PENDING) @map("status")
  approverId       Int?           @map("approver_id")
  approverComment  String?        @map("approver_comment")
  decidedAt        DateTime?      @map("decided_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id])
  approver Employee? @relation("ApproverLeave", fields: [approverId], references: [id])

  @@index([employeeId, status])
  @@index([status])
  @@map("leave_request")
}

// ============================================================
// 表5: 补卡申请
// ============================================================
model MakeupRequest {
  id               Int            @id @default(autoincrement())
  employeeId       Int            @map("employee_id")
  date             DateTime       @map("date")
  type             ClockType      @map("type")
  reason           String         @map("reason")
  attachments      String?        @map("attachments")
  status           ApproveStatus  @default(PENDING) @map("status")
  approverId       Int?           @map("approver_id")
  approverComment  String?        @map("approver_comment")
  decidedAt        DateTime?      @map("decided_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id])
  approver Employee? @relation("ApproverMakeup", fields: [approverId], references: [id])

  @@index([employeeId, status])
  @@index([status])
  @@map("makeup_request")
}

// ============================================================
// 表6: 考勤地点白名单
// ============================================================
model LocationWhitelist {
  id           Int        @id @default(autoincrement())
  name         String                              // 地点名称
  departmentId Int        @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id])
  latitude     Float      @map("latitude")
  longitude    Float      @map("longitude")
  radiusMeters Int        @default(200) @map("radius_meters")
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  managedBy   Int?      @map("managed_by")
  manager     Employee? @relation("ManagedDepartment", fields: [managedBy], references: [id])

  @@index([departmentId, isActive])
  @@map("location_whitelist")
}

// ============================================================
// 表7: 系统配置表
// ============================================================
model SystemConfig {
  id        Int        @id @default(autoincrement())
  key       String     @unique
  value     String
  type      ConfigType @default(STRING) @map("type")
  label     String                              // 配置说明
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@map("system_config")
}

// ============================================================
// 表8: 操作日志表
// ============================================================
model OperationLog {
  id         Int      @id @default(autoincrement())
  operatorId Int      @map("operator_id")
  module     String                          // 模块
  action     String                          // 操作类型
  targetType String?  @map("target_type")
  targetId   Int?     @map("target_id")
  detail     String?  @map("detail")
  ip         String?  @map("ip")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([operatorId, createdAt])
  @@index([module, action])
  @@map("operation_log")
}

// ============================================================
// 表9: 考勤规则配置表
// ============================================================
model AttendanceRule {
  id           Int      @id @default(autoincrement())
  ruleType     RuleType @map("rule_type")
  departmentId Int?     @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])
  config       Json     @map("config")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([ruleType, departmentId])
  @@map("attendance_rule")
}

// ============================================================
// 表10: 排班表
// ============================================================
model Schedule {
  id           Int      @id @default(autoincrement())
  employeeId   Int      @map("employee_id")
  scheduleDate DateTime @map("schedule_date")
  shiftType    String   @map("shift_type")
  startTime    String   @map("start_time")
  endTime      String   @map("end_time")
  status       String   @default("NORMAL")
  notes        String?  @map("notes")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, scheduleDate])
  @@map("schedule")
}

// ============================================================
// 表11: 调班申请表
// ============================================================
model ShiftChange {
  id            Int      @id @default(autoincrement())
  employeeId    Int      @map("employee_id")
  originalDate  DateTime @map("original_date")
  targetDate    DateTime @map("target_date")
  reason        String?
  status        String   @default("PENDING")
  approverId    Int?     @map("approver_id")
  approvedAt    DateTime? @map("approved_at")
  createdAt    DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])
  approver Employee? @relation("ApproverShift", fields: [approverId], references: [id])

  @@index([employeeId, status])
  @@map("shift_change")
}

// ============================================================
// 表12: 节假日表
// ============================================================
model Holiday {
  id        Int      @id @default(autoincrement())
  date      String   @unique @map("date")
  name      String   @map("name")
  isWorkday Boolean  @default(false) @map("is_workday")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("holiday")
}
